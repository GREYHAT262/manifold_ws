        "/manifold_ws/src/grid_map/grid_map_filters/include/**",
        "/manifold_ws/src/grid_map/grid_map_loader/include/**",
        "/manifold_ws/src/grid_map/grid_map_octomap/include/**",
        "/manifold_ws/src/grid_map/grid_map_pcl/include/**",
        "/manifold_ws/src/grid_map/grid_map_ros/include/**",
        "/manifold_ws/src/grid_map/grid_map_rviz_plugin/include/**",
        "/manifold_ws/src/grid_map/grid_map_sdf/include/**",
        "/manifold_ws/src/grid_map/grid_map_visualization/include/**",
        "/manifold_ws/src/local_map/include/**",
