{
  "configurations": [
    {
      "compileCommands": "${workspaceFolder}/compile_commands.json",
      "browse": {
        "databaseFilename": "${default}",
        "limitSymbolsToIncludedHeaders": false
      },
      "includePath": [
        "/manifold_ws/devel/include/**",
        "/opt/ros/melodic/include/**",
        "/manifold_ws/src/eband_local_planner/include/**",
        "/manifold_ws/src/grid_map/grid_map_core/include/**",
        "/manifold_ws/src/grid_map/grid_map_costmap_2d/include/**",
        "/manifold_ws/src/grid_map/grid_map_cv/include/**",
